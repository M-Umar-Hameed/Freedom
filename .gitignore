# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# nested app dependencies and builds
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/web-build/
desktop/ui/node_modules/
desktop/ui/dist/
desktop/target/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# local expo modules build artifacts
mobile/modules/*/android/build/
mobile/modules/*/android/.gradle/
mobile/modules/*/android/.cxx/
mobile/modules/*/ios/build/
mobile/modules/*/ios/Pods/
mobile/modules/*/ios/*.xcworkspace/

# Freedom specific
mobile/data/domains/custom/*.txt
mobile/data/keywords/custom/*.txt
!mobile/data/domains/custom/.gitkeep
!mobile/data/keywords/custom/.gitkeep
